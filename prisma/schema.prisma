generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @db.VarChar(255)
  title           String    @db.VarChar(255)
  excerpt         String    @db.Text
  content         String    @db.LongText
  category        String    @db.VarChar(100)
  tags            String    @default("") @db.VarChar(500)
  metaTitle       String    @db.VarChar(70)
  metaDescription String    @db.VarChar(170)
  ogImage         String    @default("") @db.VarChar(500)
  focusKeyword    String    @default("") @db.VarChar(100)
  readTime        String    @default("5 min read") @db.VarChar(20)
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published])
  @@index([slug])
  @@index([publishedAt])
}
